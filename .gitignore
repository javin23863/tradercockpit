# NOTE: gitignore has no trailing comments — a "#" after a pattern becomes part of it.

# credentials — never commit
# OpenMontage/ = engine + venv + .env (cloned separately, see README)
OpenMontage/
# Open-Generative-AI/ = local-only Electron studio + sd.cpp models
Open-Generative-AI/
# token.json = YouTube upload scope; token_channel.json = channel scope (videos().update)
tools/token.json
tools/token_channel.json
tools/client_secret.json
archive/postiz/.env

# python
__pycache__/
*.pyc

# generated media — regenerable from source + the recipes in tools/
# build/ = masters, VO, parts (produce.py) · shorts/*.mp4 = verticals (recut_shorts.cjs)
productions/*/build/
productions/*/shorts/*.mp4
productions/*/visuals/*.mp4
# news-work/ = cached article screenshots, ~90 MB per video
productions/*/news-work/
# ge-raw*/ = God's Eye captures
productions/*/ge-raw*/
productions/*/ge-retake/
productions/*/verify/
# _voice/ = voice-clone venv + reference audio
productions/_voice/
productions/sample-hormuz/

# tooling scratch
# dashboard.html = generated by tools/dashboard.py
dashboard.html
# handoff/shots/ = CDP screenshots (receipts, not source)
tools/handoff/shots/
studio-kit/assets/samples/
studio-kit/**/node_modules/
studio-kit/**/output/
studio-kit/tribev2/
studio-kit/pipeline/generators/compositions/cfg.json

# generated media, round 2 (2026-07-17 sweep) — new layouts the old patterns miss
# build-rejected-*/ = archived rejected masters · shorts/recut-v*/ = re-cut verticals
productions/*/build-rejected*/
productions/*/shorts/**/*.mp4
productions/*/source-footage/
productions/*/godseye-work*/
productions/*/*.wav
productions/*/*.mp4
productions/*/visuals/**/*.mp4

# sqlite side files leaked from readonly Manager snapshots
.manager-*.db-shm
.manager-*.db-wal
# qa/ + qa-sol/ = frame-audit screenshots, regenerable like verify/
productions/*/qa/
productions/*/qa-sol/

# local browser captures and traces (regenerable evidence)
/output/
