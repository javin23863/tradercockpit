# Copy to .env (gitignored) and fill. Compose interpolates these into the override.
# JWT_SECRET: any long random string, unique to this install.
JWT_SECRET=
# Same Meta app as SETUP-CREDS.md (IG/FB Reels legs):
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
# Same Google OAuth client as tools/client_secret.json:
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
# TikTok developer app (developers.tiktok.com) — this is the free TikTok route:
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=
# Optional extras:
THREADS_APP_ID=
THREADS_APP_SECRET=
X_API_KEY=
X_API_SECRET=
